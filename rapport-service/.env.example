# Variables d'environnement Railway
# Copier ce fichier en .env pour le dev local

# URL(s) autorisées en CORS (séparées par virgule)
# En production : mettre l'URL exacte de ton app Neoclima Field
ALLOWED_ORIGINS=https://ton-app.vercel.app,http://localhost:5173

# Chemin vers le logo Neoclima (PNG)
# Sur Railway : ajouter le fichier logo.png dans le repo et référencer ici
LOGO_PATH=/app/logo.png
